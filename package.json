{
	"name": "@vegardx/pi",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "pi-maestro — structured pi coding-agent extension stack",
	"license": "MIT",
	"keywords": [
		"pi-package"
	],
	"workspaces": [
		"packages/*"
	],
	"pi": {
		"extensions": [
			"packages/ask/src/index.ts",
			"packages/prompt-assist/src/index.ts",
			"packages/settings/src/extension.ts",
			"packages/subagents/src/index.ts",
			"packages/commit/src/index.ts",
			"packages/smart-compact/src/index.ts",
			"packages/modes/src/index.ts"
		],
		"skills": []
	},
	"scripts": {
		"check": "biome check . && tsc --noEmit && node scripts/check-boundaries.mjs && node scripts/check-feature-flags.mjs && node scripts/check-docs.mjs && node scripts/check-cutover.mjs && vitest run && node scripts/smoke.mjs",
		"docs": "node scripts/check-docs.mjs && node scripts/check-cutover.mjs",
		"audit:cutover": "node scripts/check-cutover.mjs",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"test:e2e:full": "vitest run --config vitest.e2e-full.config.ts",
		"e2e:driver": "jiti test/e2e/driver/cli.ts",
		"boundaries": "node scripts/check-boundaries.mjs",
		"smoke": "node scripts/smoke.mjs",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@earendil-works/pi-agent-core": "^0.80.8",
		"@earendil-works/pi-ai": "^0.80.8",
		"@earendil-works/pi-coding-agent": "^0.80.8",
		"@earendil-works/pi-tui": "^0.80.8",
		"@sinclair/typebox": "^0.34.52",
		"@types/node": "^24.13.3",
		"husky": "^9.1.7",
		"jiti": "^2.7.0",
		"semantic-release": "^25.0.8",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
