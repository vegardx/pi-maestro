{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noExplicitAny": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"correctness": {
				"noUnusedFunctionParameters": "off"
			}
		}
	},
	"overrides": [],
	"formatter": {
		"enabled": true
	},
	"files": {
		"includes": ["**/*.ts", "**/*.mjs", "!**/node_modules", "!**/dist"]
	}
}
